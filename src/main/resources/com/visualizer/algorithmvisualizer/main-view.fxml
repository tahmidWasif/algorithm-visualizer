<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<BorderPane prefWidth="1280" prefHeight="720"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.visualizer.algorithmvisualizer.MainController"
            stylesheets="@styles.css">
    <center>
        <VBox alignment="CENTER" style="-fx-background-color: rgb(0, 0, 0, 0.6); -fx-font-family: Consolas;">

                <Label fx:id="headingMain" style="-fx-font-size: 35; -fx-font-family: Consolas; -fx-font-weight: bold; -fx-text-fill: white;" translateY="-70" >Welcome to Algorithm Visualizer</Label>
                <Button fx:id="switchToSort" onAction="#switchToSorting" text="Sorting Algorithms" translateY="-60"/>
                <Button fx:id="switchToGraph" onAction="#switchToGraph" text="Graph Algorithms" translateY="-55"/>

        </VBox>
    </center>
</BorderPane>
